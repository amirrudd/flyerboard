{
  "name": "flex-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite --open",
    "dev:backend": "convex dev",
    "build": "vite build",
    "lint": "tsc -p convex -noEmit --pretty false && tsc -p . -noEmit --pretty false && convex dev --once && vite build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@convex-dev/auth": "^0.0.94",
    "@convex-dev/r2": "^0.10.2",
    "@convex-dev/resend": "^0.2.5",
    "@descope/react-sdk": "^2.29.5",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/js-cookie": "^3.0.6",
    "@vercel/speed-insights": "^2.0.0",
    "@vis.gl/react-google-maps": "^1.7.1",
    "axios": "^1.18.1",
    "browser-image-compression": "^2.0.2",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "convex": "^1.42.0",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.0",
    "js-cookie": "^3.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-lazy-load-image-component": "^1.6.3",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/google.maps": "^3.65.2",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-lazy-load-image-component": "^1.6.5",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "dotenv": "^17.2.4",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "convex-helpers": "^0.1.116"
  }
}
