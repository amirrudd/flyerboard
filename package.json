{
  "name": "flex-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite --open",
    "dev:backend": "convex dev",
    "build": "vite build && tsx scripts/generate-og-assets.ts",
    "lint": "eslint . && tsc -p convex -noEmit --pretty false && tsc -b --pretty false && convex dev --once && vite build && tsx scripts/generate-og-assets.ts",
    "lint:eslint": "eslint .",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/s3-request-presigner": "^3.1086.0",
    "@convex-dev/auth": "^0.0.94",
    "@convex-dev/r2": "^0.10.2",
    "@convex-dev/resend": "^0.2.5",
    "@descope/react-sdk": "^2.30.5",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/js-cookie": "^3.0.6",
    "@vercel/edge": "^1.3.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.18.1",
    "browser-image-compression": "^2.0.2",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "convex": "^1.42.2",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "js-cookie": "^3.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.24.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-lazy-load-image-component": "^1.6.3",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-lazy-load-image-component": "^1.6.5",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "convex-test": "^0.0.54",
    "dotenv": "^17.2.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "convex-helpers": "^0.1.116"
  }
}
